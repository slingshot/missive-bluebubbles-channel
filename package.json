{
  "name": "missive-bluebubbles-channel",
  "version": "0.1.0",
  "description": "Bidirectional bridge between Missive custom channels and a self-hosted BlueBubbles iMessage server (Bun + Elysia).",
  "type": "module",
  "private": true,
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:cov": "bun test --coverage",
    "format": "biome format --write .",
    "lint": "biome check ."
  },
  "dependencies": {
    "elysia": "^1.4.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@types/bun": "^1.3.5",
    "typescript": "^5.9.3"
  }
}
