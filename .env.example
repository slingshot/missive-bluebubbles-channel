# ---------------------------------------------------------------------------
# BlueBubbles <-> Missive bridge configuration.
# Copy to `.env` and fill in. The process fails fast at boot if any REQUIRED
# variable is missing/empty (see src/config.ts). Secrets are never logged.
# ---------------------------------------------------------------------------

# === REQUIRED ===============================================================

# Base URL of your self-hosted BlueBubbles server (local or remote, no trailing
# slash). The REST base is `<BB_URL>/api/v1`.
# Docker: to reach BlueBubbles on the host, either leave this unset (Compose
# defaults it to http://host.docker.internal:1234) or set it explicitly to
# http://host.docker.internal:1234. For a remote server, set its reachable URL.
BB_URL=http://localhost:1234

# BlueBubbles server password. Sent as `?password=...` on every BB API call.
BB_PASSWORD=changeme

# Missive personal access token (looks like `missive_pat-...`). Sent as
# `Authorization: Bearer <token>` to the Missive REST API.
MISSIVE_TOKEN=missive_pat-xxxxxxxxxxxxxxxxxxxxxxxx

# Missive custom-channel id. REQUIRED `account` field on every inbound message
# POST. Copy it from the channel settings after creating the channel.
MISSIVE_ACCOUNT_ID=00000000-0000-0000-0000-000000000000

# Shared secret for the Missive outbound webhook. The bridge verifies
# `X-Hook-Signature: sha256=HMAC_SHA256_hex(rawBody, secret)` on the raw bytes.
MISSIVE_HMAC_SECRET=replace-with-the-missive-signing-secret

# The bridge's own public HTTPS base URL (no trailing slash). Used to build the
# BlueBubbles webhook target `${PUBLIC_URL}/bb/webhook/${BB_HOOK_TOKEN}`.
# Never derived from a request host header.
PUBLIC_URL=https://bridge.example.com

# Random token (32+ chars) guarding the unsigned BlueBubbles webhook endpoint.
# Generate with: `openssl rand -hex 24`
BB_HOOK_TOKEN=replace-with-32-plus-random-characters-xxxx

# The Mac's own iMessage address (phone/email). Used as inbound `to_fields[0]`
# so incoming messages thread to the right channel identity.
SELF_HANDLE=+15555550123

# === OPTIONAL (defaults shown) ==============================================

# Display name for the bridge's own identity (self-from-other-device posts).
SELF_NAME=Me

# HTTP port the bridge listens on.
PORT=3000

# Path to the SQLite database file (source of truth: mappings, dedup, outbox).
DB_PATH=./data/bridge.sqlite

# Service used for brand-new outbound conversations: `iMessage` or `SMS`.
DEFAULT_SERVICE=iMessage

# If `true`, download attachments in their original encoding. If `false`,
# request `?original=false` so BlueBubbles transcodes HEIC->JPEG / caf->mp3 for
# previewability in Missive.
ATTACHMENT_ORIGINAL=false

# Hard cap for a single inbound Missive POST body (base64 inflates ~33%; the
# whole JSON body must stay <= 10 MB). Larger files are split or placeholdered.
MISSIVE_MAX_PAYLOAD_BYTES=9500000

# If `true`, surface delivered/read receipts as Missive Posts comments.
RECEIPTS_AS_POSTS=false

# Interval (ms) for re-probing BlueBubbles Private-API capability.
CAPS_REPROBE_MS=300000

# Optional token (32+ chars) enabling the monitoring dashboard at
# `/dashboard/<token>`. Unset (default) disables the dashboard entirely (the
# routes return 404). Treat the URL as a secret; generate with:
# `openssl rand -hex 24`
# DASHBOARD_TOKEN=

# Log verbosity: `debug` | `info` | `warn` | `error`.
LOG_LEVEL=info
